---
import "../styles/global2.css"
import NavBar from '../components/composite/NavBar.svelte'
import LogoHeader from '../components/composite/LogoHeader.astro'

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<html>
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <link rel="shortcut icon" href="/favicon.png" type="image/x-icon" />
    <title>{title}</title>
  </head>
  <body>
    <div id="root" class="root-grid">
      <header class="subgrid col-3 row-3">
        <LogoHeader/>
        <NavBar currentPath={Astro.url.pathname} lang="en" />
      </header>
      <main class="subgrid col-5 row-8">
        <slot />
      </main>
      <aside class="subgrid col-3 row-5">
        <slot name="sidebar" />
      </aside>
    </div>
  </body>
</html>

<style>
  #root {
    --grid-cols: 8;
    --grid-rows: 8;

    width: 100%;
    height: 100vh;
    padding: var(--padding-container);

    /* --cols-a: 5;
    --cols-b: calc(var(--grid-cols) - var(--cols-a));
    --rows-a: 5;
    --rows-b: calc(var(--grid-rows) - var(--rows-a));

    > header {
      --local-cols: var(--cols-b);
      --local-rows: var(--rows-b);
    }

    > main {
      --local-cols: var(--cols-a);
      --local-rows: var(--grid-rows);
      --parent-cols: var(--local-cols);
      --parent-rows: var(--local-rows);
    }

    > aside {
      --local-cols: var(--cols-b);
      --local-rows: var(--rows-a);
    } */
  }
</style>
