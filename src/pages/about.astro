---
import Icon from "../components/base/Icon.svelte"
import Image from "../components/base/Image.svelte"
import NavItem from "../components/base/NavItem.svelte"
import CurrentlyReading from "../components/composite/CurrentlyReading.svelte"
import GitContributions from "../components/composite/GitContributions.svelte"
import TopTrack from "../components/composite/TopTrack.svelte"
import { pages } from "../data/site/pages"
import BaseLayout from "../layouts/BaseLayout.astro"

let theme = Astro.cookies.get('theme')?.value || 'default'
---

<BaseLayout title="About">
  <div class="about-heading col-full row-1 align-end flex between baseline">
    <div class="about-title">
      <div class="flourishes flex">
        <div class="flourish1">~</div>
        <div class="flourish2">»</div>
      </div>
      <h1>whoami</h1>
    </div>
    <nav class="user-links flex baseline gap-large">
      <NavItem icon="github" href="https://github.com/orangeburrito">GitHub</NavItem>
      <NavItem icon="linkedin" href="https://l.georedir.com/orangelinkedin">LinkedIn</NavItem>
      <NavItem icon="book" href="https://app.thestorygraph.com/profile/orangeburrito">StoryGraph</NavItem>
      <NavItem icon="paint" href="https://userstyles.world/user/orangeburrito">UserStyles</NavItem>
    </nav>
  </div>
  <div class="subgrid row-6">
    <div class="subgrid row-3">
      <div class="section first col-fill row-full"
        set:html={pages.about.description}>
      </div>
      <div class="col-2 row-full">
        <Image src="/images/mysterious_visage2.png" alt="" caption={pages.about.caption} />
      </div>
    </div>
    <div class="section second subgrid row-3">
      <div class="col-2 row-full">
        <Image src="/images/hotcocoa.png" alt="" caption={pages.about.caption2} />
      </div>
      <div class="col-fill row-full"
        set:html={pages.about.description2}>
      </div>
    </div>
  </div>
  <div class="spacer"></div>
  <div class="blockquote col-3 row-1 offset-col-half offset-row-gap-none">
    <p>{pages.about.quote}</p>
    <p class="subtle">— {pages.about.quoteAuthor}</p>
  </div>

  <Fragment slot="sidebar">
    <div class="subgrid col-2 row-full flex vertical end-y">
      <div class="col-full row-1 flex between baseline gap-none">
        <h3 class="subtle flex">
          <Icon icon="live" />
          User Status
        </h3>
        <em class="small">Updated Daily</em>
      </div>
      <div class="container sidebar col-full row-fill fill-x">
        <CurrentlyReading client:load />
        <TopTrack client:load />
        <GitContributions client:load />
      </div>
    </div>
  </Fragment>
</BaseLayout>

<style>
  img {
    width: 100%;
    min-height: 50px;
    height: auto;
    border: 1px solid gray;
  }

  .about-title {
    anchor-name: --page-title;
    h1 {
      color: var(--color-tertiary);
      height: var(--font-size-heading-large);
    }

    .flourishes {
      position: absolute;
      position-anchor: --page-title;
      position-area: center left;
      margin-top: var(--space-150);
      margin-right: var(--space-200);
      font-size: var(--font-size-heading-large);
      font-weight: 500;

      .flourish1 {
        color: var(--color-secondary);
      }
      .flourish2 {
        color: var(--color-primary);
      }
    }
  }

  .user-links {
    box-shadow: inset 0 -6px 0 var(--color-border-alt);
  }

  .section {
    &.first {
      padding-right: var(--space-100);
    }

    h4, h5 {
      margin-bottom: var(--space-050);
    }

    p, ul {
      margin-bottom: var(--space-100);
    }
  }

  @media screen and (max-width: 600px) {
    .about-heading.align-end {
      flex-direction: column;
      align-items: flex-start !important;

      .user-links {
        position: absolute;
        flex-direction: column;
        right: var(--padding-container);
        gap: var(--space-100);
        box-shadow: inset -6px 0 0 var(--color-border-alt);
        margin-top: var(--space-100);

        .nav-item {
          flex-direction: row-reverse;
        }
      }

      .about-title {
        display: flex;
        align-items: center;

        .flourishes {
          position: relative;
          margin-top: 0;

          .flourish1, .flourish2 {
            height: var(--space-400);
          }
        }
      }
    }

    .section.first {
      padding-right: 0;
    }

    .section.second {
      display: flex;
      flex-direction: column-reverse;
    }
  }
</style>